# API pública mínima — solo na-feed.php
Options -Indexes

<FilesMatch "^\.">
  Require all denied
</FilesMatch>

<FilesMatch "\.(sql|log|ini|bak|env|md|txt|sample|example)$">
  Require all denied
</FilesMatch>

<FilesMatch "^(config|bootstrap|db|mailer)\.php$">
  Require all denied
</FilesMatch>

<FilesMatch ".*_cron\.php$">
  Require all denied
</FilesMatch>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "DENY"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
