# Copia a .env.local para desarrollo o pásalas al build de producción.
# Ver docs/ANALYTICS-SEO.md

# URL pública del sitio (build cPanel)
NEXT_PUBLIC_SITE_URL=https://acropolis.adesa.com.do

# Google Analytics 4 — ID de medición (Admin → Flujos de datos → Web → ID G-XXXXXXXXXX)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console — meta verification (Propiedad → Verificación → Etiqueta HTML → content="...")
# NEXT_PUBLIC_GSC_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
