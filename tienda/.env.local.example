# Copiar a .env.local (no subir a git)

# Sitio público (build GitHub Pages / producción)
# NEXT_PUBLIC_SITE_URL=https://tienda.acropolis.org.do

# API catálogo + checkout — hoy Biblioteca; mañana Harmonía (Railway)
# NEXT_PUBLIC_STORE_API_URL=https://biblioteca-oina.adesa.com.do
# Cuando Harmonía tenga el módulo tienda:
# NEXT_PUBLIC_STORE_API_URL=https://na-harmonia.up.railway.app
# NEXT_PUBLIC_STORE_CATALOG_PATH=/api/store/catalog
# NEXT_PUBLIC_STORE_CHECKOUT_PATH=/api/store/checkout

# CMS editorial (opcional; Harmonío/Railway más adelante)
# NEXT_PUBLIC_CMS_URL=https://editor.acropolis.org.do/api
